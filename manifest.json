{
  "manifest_version": 3,
  "name": "Prompt Marks",
  "version": "2.0",
  "description": "ChatGPT message navigator - jump between your sent messages instantly",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
